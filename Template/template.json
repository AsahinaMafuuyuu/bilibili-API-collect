{
  "openapi": "3.0.3",
  "info": {
    "title": "Bilibili 热搜与默认搜索 OpenAPI",
    "version": "1.1.0",
    "description": "基于用户提供的 `hot.md` 文档整理的标准 OpenAPI 3.0.3 描述文件。本文件重点补全了接口用途说明、鉴权说明、参数约束、响应模型、字段注释与示例，便于直接导入 Apifox / Postman 并生成快捷请求。\n\n说明：\n1. 文档中的部分字段含义在源文档中标记为“未知/大概是吧”，此处保留为“推测字段”，并在 description 中明确标注。\n2. `wbi` 接口需要 WBI 签名；OpenAPI 仅描述参数，不负责生成签名。\n3. 同名字段在不同端返回结构可能略有差异，已按来源分别建模。"
  },
  "servers": [
    {
      "url": "https://api.bilibili.com",
      "description": "主站 API 服务"
    },
    {
      "url": "https://s.search.bilibili.com",
      "description": "搜索服务域名（web 热搜）"
    },
    {
      "url": "https://app.bilibili.com",
      "description": "移动端 API 服务"
    }
  ],
  "tags": [
    {
      "name": "默认搜索",
      "description": "搜索框默认推荐词相关接口"
    },
    {
      "name": "热搜-Web(WBI)",
      "description": "Web 端 WBI 热搜列表接口"
    },
    {
      "name": "热搜-Web(Search Service)",
      "description": "搜索服务域名下的热搜榜接口"
    },
    {
      "name": "热搜-App",
      "description": "移动端热搜排行接口"
    }
  ],
  "components": {
    "securitySchemes": {
      "Buvid3Cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "buvid3",
        "description": "部分 WBI 接口在实际请求中可能依赖 `buvid3`。是否强制取决于服务端风控与签名校验。"
      }
    },
    "parameters": {
      "Wts": {
        "name": "wts",
        "in": "query",
        "required": true,
        "description": "WBI 签名时间戳，通常为 Unix 秒级时间戳。",
        "schema": {
          "type": "integer",
          "format": "int64",
          "example": 1713427200
        }
      },
      "WRid": {
        "name": "w_rid",
        "in": "query",
        "required": true,
        "description": "WBI 签名结果。由请求参数拼接后结合 WBI 算法计算得到。",
        "schema": {
          "type": "string",
          "example": "0123456789abcdef0123456789abcdef"
        }
      },
      "LimitWebSquare": {
        "name": "limit",
        "in": "query",
        "required": true,
        "description": "返回热搜条目数，取值范围 `[1, 50]`。",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "example": 10
        }
      },
      "Platform": {
        "name": "platform",
        "in": "query",
        "required": false,
        "description": "平台标识。源文档给出的典型值为 `web`。",
        "schema": {
          "type": "string",
          "default": "web",
          "example": "web"
        }
      },
      "AppLimit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "description": "热搜数量。缺省为 20，最大为 100。",
        "schema": {
          "type": "integer",
          "default": 20,
          "maximum": 100,
          "minimum": 1,
          "example": 20
        }
      }
    },
    "schemas": {
      "BaseCodeMessageTtl": {
        "type": "object",
        "description": "Bilibili 常见响应包裹结构。",
        "properties": {
          "code": {
            "type": "integer",
            "description": "业务状态码。0 表示成功。",
            "example": 0
          },
          "message": {
            "type": "string",
            "description": "业务错误信息。成功时通常为 `0` 或 `success`。",
            "example": "0"
          },
          "ttl": {
            "type": "integer",
            "description": "响应 TTL，通常固定为 1。",
            "example": 1
          }
        },
        "required": [
          "code",
          "message",
          "ttl"
        ]
      },
      "DefaultSearchData": {
        "type": "object",
        "description": "默认搜索内容对象。当用户在搜索框未输入内容直接搜索时，通常可跳转至该对象给出的 `url`。",
        "properties": {
          "seid": {
            "type": "string",
            "description": "搜索会话标识。",
            "example": "17607543598496143098"
          },
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "默认搜索条目的内部 ID。",
            "example": 3296036255232726331
          },
          "type": {
            "type": "integer",
            "description": "条目类型。源文档示例为 `0`。",
            "example": 0
          },
          "show_name": {
            "type": "string",
            "description": "搜索框中展示给用户的默认关键词。",
            "example": "歪果仁在中国做模特能赚多少钱？"
          },
          "name": {
            "type": "string",
            "description": "额外名称字段。源文档示例为空字符串。",
            "example": ""
          },
          "goto_type": {
            "type": "integer",
            "description": "跳转类型。源文档示例中 `1` 表示视频。",
            "example": 1
          },
          "goto_value": {
            "type": "string",
            "description": "跳转目标 ID。若 `goto_type=1`，通常为稿件 avid。",
            "example": "243920322"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "默认搜索目标跳转链接。",
            "example": "https://www.bilibili.com/video/BV1Tv411q7gx"
          }
        },
        "required": [
          "seid",
          "id",
          "type",
          "show_name",
          "name",
          "goto_type",
          "goto_value",
          "url"
        ]
      },
      "DefaultSearchResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseCodeMessageTtl"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/DefaultSearchData"
              }
            },
            "required": [
              "data"
            ]
          }
        ]
      },
      "WebSquareItem": {
        "type": "object",
        "description": "Web 端热搜项。",
        "properties": {
          "keyword": {
            "type": "string",
            "description": "原始关键词。",
            "example": "马克龙祝贺中国世界前两名"
          },
          "show_name": {
            "type": "string",
            "description": "展示文本。通常与 `keyword` 相同。",
            "example": "马克龙祝贺中国世界前两名"
          },
          "icon": {
            "type": "string",
            "format": "uri",
            "description": "热搜标签图标 URL。",
            "example": "http://i0.hdslb.com/bfs/activity-plat/static/example.png"
          },
          "uri": {
            "type": "string",
            "description": "附加跳转 URI。源文档示例为空。",
            "example": ""
          },
          "goto": {
            "type": "string",
            "description": "附加跳转类型。源文档示例为空。",
            "example": ""
          }
        },
        "required": [
          "keyword",
          "show_name",
          "icon",
          "uri",
          "goto"
        ]
      },
      "WebSquareTrending": {
        "type": "object",
        "description": "热搜榜主体对象。",
        "properties": {
          "title": {
            "type": "string",
            "description": "榜单标题。",
            "example": "bilibili热搜"
          },
          "trackid": {
            "type": "string",
            "description": "跟踪 ID。源文档未明确说明用途。",
            "example": "8079760748892487175"
          },
          "list": {
            "type": "array",
            "description": "热搜条目列表。",
            "items": {
              "$ref": "#/components/schemas/WebSquareItem"
            }
          },
          "top_list": {
            "type": "array",
            "description": "扩展榜单列表。源文档示例为空数组。",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "title",
          "trackid",
          "list",
          "top_list"
        ]
      },
      "WebSquareData": {
        "type": "object",
        "properties": {
          "trending": {
            "$ref": "#/components/schemas/WebSquareTrending"
          }
        },
        "required": [
          "trending"
        ]
      },
      "WebSquareResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseCodeMessageTtl"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/WebSquareData"
              }
            },
            "required": [
              "data"
            ]
          }
        ]
      },
      "SearchServiceCost": {
        "type": "object",
        "description": "搜索服务耗时统计对象。各字段通常为字符串形式的小数秒。",
        "properties": {
          "reas_request": {
            "type": "string",
            "example": "0.001895"
          },
          "params_check": {
            "type": "string",
            "example": "0.000127"
          },
          "reas_response_format": {
            "type": "string",
            "example": "0.000098"
          },
          "deserialize_response": {
            "type": "string",
            "example": "0.000080"
          },
          "reas_request_format": {
            "type": "string",
            "example": "0.000076"
          },
          "total": {
            "type": "string",
            "example": "0.002479"
          },
          "main_handler": {
            "type": "string",
            "example": "0.002252"
          }
        },
        "additionalProperties": {
          "type": "string"
        }
      },
      "SearchServiceHotwordItem": {
        "type": "object",
        "description": "搜索服务热搜项。部分字段实际语义在源文档中未完全确认，已保留说明。",
        "properties": {
          "status": {
            "type": "string",
            "description": "状态字段，源文档示例为空字符串。",
            "example": ""
          },
          "hot_id": {
            "type": "integer",
            "description": "热词 ID。",
            "example": 11003
          },
          "keyword": {
            "type": "string",
            "description": "关键词。",
            "example": "流浪地球2刘德华"
          },
          "resource_id": {
            "type": "integer",
            "description": "资源 ID。源文档未明确说明具体含义。",
            "example": 0
          },
          "goto_type": {
            "type": "integer",
            "description": "跳转类型。示例为 0。",
            "example": 0
          },
          "res": {
            "type": "array",
            "description": "附加资源数组，示例通常为空。",
            "items": {},
            "example": []
          },
          "show_name": {
            "type": "string",
            "description": "完整展示关键词。",
            "example": "流浪地球2刘德华造型"
          },
          "pos": {
            "type": "integer",
            "description": "榜单名次，范围通常为 1~10。",
            "example": 1
          },
          "word_type": {
            "type": "integer",
            "description": "条目属性。常见取值：4=新、5=热、6=特殊活动/节日标签、7=直播中、8=默认、9=梗、11=话题、12=独家。",
            "example": 8
          },
          "id": {
            "type": "integer",
            "description": "名次 ID。通常与 `pos` 一致。",
            "example": 1
          },
          "goto_value": {
            "type": "string",
            "description": "跳转值，示例通常为空字符串。",
            "example": ""
          },
          "live_id": {
            "type": "array",
            "description": "直播相关 ID 数组，示例通常为空。",
            "items": {},
            "example": []
          },
          "name_type": {
            "type": "string",
            "description": "名称类型字段，示例为空字符串。",
            "example": ""
          },
          "icon": {
            "type": "string",
            "description": "图标 URL，可为空。",
            "example": "http://i0.hdslb.com/bfs/feed-admin/example.png"
          }
        },
        "required": [
          "status",
          "hot_id",
          "keyword",
          "resource_id",
          "goto_type",
          "res",
          "show_name",
          "pos",
          "word_type",
          "id",
          "goto_value",
          "live_id",
          "name_type",
          "icon"
        ]
      },
      "SearchServiceHotwordResponse": {
        "type": "object",
        "properties": {
          "exp_str": {
            "type": "string",
            "description": "实验参数或埋点字段，源文档未明确说明。",
            "example": "8104#8200#8300#8401#8500#5502#6699"
          },
          "code": {
            "type": "integer",
            "description": "业务状态码，0 表示成功。",
            "example": 0
          },
          "cost": {
            "$ref": "#/components/schemas/SearchServiceCost"
          },
          "seid": {
            "type": "string",
            "description": "搜索会话标识。",
            "example": "9318821020548476185"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64",
            "description": "榜单统计时间戳。",
            "example": 1596034742
          },
          "message": {
            "type": "string",
            "description": "错误信息。成功时通常为 `success`。",
            "example": "success"
          },
          "list": {
            "type": "array",
            "description": "热搜榜列表，通常固定前 10 条。",
            "items": {
              "$ref": "#/components/schemas/SearchServiceHotwordItem"
            }
          }
        },
        "required": [
          "exp_str",
          "code",
          "cost",
          "seid",
          "timestamp",
          "message",
          "list"
        ]
      },
      "AppHotwordItem": {
        "type": "object",
        "description": "移动端热搜项。",
        "properties": {
          "position": {
            "type": "integer",
            "description": "榜单位置。",
            "example": 1
          },
          "keyword": {
            "type": "string",
            "description": "原始关键词。",
            "example": "列车延误乘务员哽咽安抚乘客"
          },
          "show_name": {
            "type": "string",
            "description": "展示关键词。",
            "example": "列车延误乘务员哽咽安抚乘客"
          },
          "word_type": {
            "type": "integer",
            "description": "条目属性，同 Web 热搜。",
            "example": 5
          },
          "icon": {
            "type": "string",
            "description": "图标 URL，可缺省。",
            "example": "http://i0.hdslb.com/bfs/activity-plat/static/example.png"
          },
          "hot_id": {
            "type": "integer",
            "description": "热词 ID。",
            "example": 107814
          },
          "is_commercial": {
            "type": "string",
            "description": "是否商业条目，示例中为字符串 `0`。",
            "example": "0"
          }
        },
        "required": [
          "position",
          "keyword",
          "show_name",
          "word_type",
          "hot_id"
        ]
      },
      "AppTrendingData": {
        "type": "object",
        "properties": {
          "trackid": {
            "type": "string",
            "description": "跟踪 ID / 埋点字段。",
            "example": "2578006123492681222"
          },
          "list": {
            "type": "array",
            "description": "热搜榜单列表。",
            "items": {
              "$ref": "#/components/schemas/AppHotwordItem"
            }
          },
          "exp_str": {
            "type": "string",
            "description": "实验字段。",
            "example": "8000#5508#6604#7703"
          },
          "hotword_egg_info": {
            "type": "string",
            "description": "热词彩蛋相关信息。源文档示例为字符串 `0`。",
            "example": "0"
          }
        },
        "required": [
          "trackid",
          "list"
        ]
      },
      "AppTrendingResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BaseCodeMessageTtl"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/AppTrendingData"
              }
            },
            "required": [
              "data"
            ]
          }
        ]
      },
      "GenericErrorResponse": {
        "type": "object",
        "description": "通用错误结构。部分接口失败时 `data` 可能为 null，部分接口则不存在 `data` 字段。",
        "properties": {
          "code": {
            "oneOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              }
            ],
            "example": -400
          },
          "message": {
            "type": "string",
            "example": "bad request"
          },
          "ttl": {
            "type": "integer",
            "nullable": true,
            "example": 1
          },
          "data": {
            "nullable": true
          }
        },
        "required": [
          "code",
          "message"
        ]
      }
    }
  },
  "paths": {
    "/x/web-interface/wbi/search/default": {
      "get": {
        "tags": [
          "默认搜索"
        ],
        "summary": "获取 Web 端默认搜索内容",
        "description": "返回搜索框默认填充内容，用于官方推荐词或推荐跳转目标。当用户未输入关键词直接点击搜索时，前端通常会根据返回的 `url` 进行跳转。\n\n鉴权说明：\n- 该接口属于 WBI 接口，需要提供 `wts` 与 `w_rid`。\n- 源文档指出实际请求可带 `buvid3` cookie，以减少风控或配合验签。\n\n兼容说明：\n- 旧路径 `https://api.bilibili.com/x/web-interface/search/default` 已被标记为旧链接。",
        "operationId": "getWebDefaultSearch",
        "parameters": [
          {
            "$ref": "#/components/parameters/Wts"
          },
          {
            "$ref": "#/components/parameters/WRid"
          }
        ],
        "security": [
          {
            "Buvid3Cookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回默认搜索信息。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DefaultSearchResponse"
                },
                "examples": {
                  "success": {
                    "summary": "成功示例",
                    "value": {
                      "code": 0,
                      "message": "0",
                      "ttl": 1,
                      "data": {
                        "seid": "17607543598496143098",
                        "id": 3296036255232726331,
                        "type": 0,
                        "show_name": "歪果仁在中国做模特能赚多少钱？",
                        "name": "",
                        "goto_type": 1,
                        "goto_value": "243920322",
                        "url": "https://www.bilibili.com/video/BV1Tv411q7gx"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "参数缺失、格式错误或 WBI 签名错误。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericErrorResponse"
                }
              }
            }
          },
          "412": {
            "description": "风控拦截。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/x/web-interface/wbi/search/square": {
      "get": {
        "tags": [
          "热搜-Web(WBI)"
        ],
        "summary": "获取 Web 端热搜列表（WBI）",
        "description": "返回 Web 端热搜榜。该接口需要 WBI 签名，支持通过 `limit` 控制返回条数。\n\n业务说明：\n- `data.trending.list` 为主要热搜列表。\n- `data.trending.top_list` 在示例中为空数组，预留给额外榜单结构。\n\n鉴权说明：\n- 需要 `wts` + `w_rid`。\n- 部分请求场景建议附带 `buvid3` cookie。",
        "operationId": "getWebHotSearchSquare",
        "parameters": [
          {
            "$ref": "#/components/parameters/LimitWebSquare"
          },
          {
            "$ref": "#/components/parameters/Platform"
          },
          {
            "$ref": "#/components/parameters/Wts"
          },
          {
            "$ref": "#/components/parameters/WRid"
          }
        ],
        "security": [
          {
            "Buvid3Cookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回热搜榜。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebSquareResponse"
                },
                "examples": {
                  "success": {
                    "value": {
                      "code": 0,
                      "message": "0",
                      "ttl": 1,
                      "data": {
                        "trending": {
                          "title": "bilibili热搜",
